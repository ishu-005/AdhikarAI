{
  "buildCommand": "echo 'Static build complete'",
  "outputDirectory": "./",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://adhikarai-backend.onrender.com/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "@adhikarai_api_url"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
