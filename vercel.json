{
  "buildCommand": "echo 'Static build complete'",
  "outputDirectory": "frontend/",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://adhikarai-backend.onrender.com/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/templates/index.html"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}

